{
  "name": "n8n-nodes-digi-tech-sdk",
  "version": "0.1.0",
  "description": "N8N community node for Digi Tech SDK — integrates with the Digi API to manage records and files.",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/digiventures/n8n-nodes-digi-tech-sdk",
  "author": {
    "name": "Digiventures",
    "email": "dev@digiventures.la"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digiventures/n8n-nodes-digi-tech-sdk.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "cp nodes/DigiTechSdk/digi-tech.svg dist/nodes/DigiTechSdk/digi-tech.svg",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint nodes credentials --ext .ts",
    "lintfix": "eslint nodes credentials --ext .ts --fix"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DigiTechSdkApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DigiTechSdk/DigiTechSdk.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "n8n-core": "*",
    "n8n-workflow": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "digi-tech-sdk": "latest"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
